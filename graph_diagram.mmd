%%{init: {"theme": "base", "flowchart": {"htmlLabels": true, "curve": "linear"}}}%%
%% S.ymphony 최종 아키텍처
%% 실제 LangGraph 노드 8개 · 3계층 · 조건부 루프 2개 · HITL 인터럽트 1개
flowchart TB

    subgraph DET["정량 · 결정론 계층  |  Python · NumPy"]
        direction LR
        START((START))
        N1["① load_inputs<br/>고객 정보 · 6개 자산 비중 입력<br/>config 정규화 · approval=draft"]
        N3["③ conflict_check<br/>버전 정책 기반 IPS 적합성 검사<br/>block/review · policy_hash 기록"]
        N5["⑤ var_engine<br/>실데이터·Parquet 캐시 로드<br/>Historical VaR·CVaR·스트레스·신뢰구간<br/>computation_hash 생성"]
        N8["⑧ assemble_report<br/>수치·승인·인용·Judge 결과 통합<br/>재현성·거버넌스·감사 정보 조립"]
        END((END))

        START --> N1
        N1 ~~~ N3
        N3 ~~~ N5
        N5 ~~~ N8
        N8 --> END
    end

    subgraph LLM["LLM · RAG 계층  |  Azure OpenAI · LangChain"]
        direction LR
        N2["② extract_ips<br/>GPT-4o Structured Output<br/>IPS 고정값 적용 · 추출 메타데이터·해시 기록"]
        N6["⑥ rag_cite<br/>4개 코퍼스 자동 라우팅<br/>methodology · macro · house_view · tax<br/>검증 통과 citation만 State에 저장"]
        N7["⑦ judge_eval<br/>결정론 필수 검사 + 6축 LLM 루브릭<br/>출처·수치·환각·정밀성·면책·금지표현<br/>판정 사유·재시도 로그 기록"]

        N2 ~~~ N6
        N6 --> N7
    end

    subgraph HITL["Human-in-the-Loop 계층  |  LangGraph interrupt"]
        direction LR
        PAUSE["⏸ approval_gate 직전 중단<br/>PB가 IPS·포트폴리오·충돌 내역 검토"]
        N4["④ approval_gate<br/>reviewed 상태와 PB 승인 조건 검증<br/>approved / exception_approved → locked<br/>승인 범위: 리스크 계산 전용"]
        STOP["입력 보완 후 재실행<br/>block은 예외 승인 불가"]

        PAUSE --> N4
        N4 -. "block" .-> STOP
    end

    %% 기본 실행 경로
    N1 -->|"정규화된 raw_input · portfolio · run_config"| N2
    N2 -->|"ips · liquidity_required · extraction_meta"| N3
    N3 -->|"충돌 없음 또는 재추출 1회 소진"| PAUSE
    N4 -->|"approval.status = locked"| N5
    N5 -->|"metrics · computation_hash"| N6
    N7 -->|"통과 또는 judge_retries ≥ 2<br/>실패 지속 시 수동검토 표시"| N8

    %% 조건부 재실행 경로
    N3 -. "충돌 있음 & conflict_retries < 1<br/>IPS 구조화 1회 재확인" .-> N2
    N7 -. "미통과 & judge_retries < 2<br/>피드백 반영 후 RAG 재작성" .-> N6

    %% 그래프 외 공통 감사 요소
    AUDIT["공통 감사 · 관측성 〔그래프 노드 아님〕<br/>RiskState 체크포인트 · 정책/프롬프트/계산 해시<br/>LangSmith input·analysis trace URL · 입력/출력 마스킹"]
    N2 -.-> AUDIT
    N3 -.-> AUDIT
    N5 -.-> AUDIT
    N6 -.-> AUDIT
    N7 -.-> AUDIT
    N8 -.-> AUDIT

    CONFLICT["conflict_check 대표 기준 〔정책 기반〕<br/>block: 필수정보 누락 · 유동성 필요액이 총자산 초과<br/>review: 유동성 30% 초과 · 균형형 위험자산 60% 초과<br/>단일 위험자산 40% 초과 · 1년 미만 위험자산 보유"]
    N3 -.-> CONFLICT

    classDef deterministic fill:#FFFFFF,stroke:#3B5CCC,color:#111827,stroke-width:2px;
    classDef llmNode fill:#FFFFFF,stroke:#7440B8,color:#111827,stroke-width:2px;
    classDef hitlNode fill:#FFFFFF,stroke:#08A26A,color:#111827,stroke-width:2px;
    classDef terminal fill:#172033,stroke:#172033,color:#FFFFFF,stroke-width:2px;
    classDef stop fill:#FFF1F2,stroke:#DC2626,color:#991B1B,stroke-width:1.5px;
    classDef audit fill:#FFF7E6,stroke:#D97706,color:#7C2D12,stroke-width:1.5px,stroke-dasharray:5 3;
    classDef note fill:#F8FAFC,stroke:#64748B,color:#334155,stroke-width:1.5px,stroke-dasharray:5 3;

    class N1,N3,N5,N8 deterministic;
    class N2,N6,N7 llmNode;
    class PAUSE,N4 hitlNode;
    class START,END terminal;
    class STOP stop;
    class AUDIT audit;
    class CONFLICT note;

    style DET fill:#EDF4FC,stroke:#CBD5E1,stroke-width:1px
    style LLM fill:#F6F0FF,stroke:#D8C7EE,stroke-width:1px
