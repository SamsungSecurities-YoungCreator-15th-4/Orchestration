flowchart TD
    START([START]) --> load_inputs

    subgraph DET["결정론 계층 (Deterministic)"]
        load_inputs["★결정론 load_inputs<br/>config·입력 정규화"]
        conflict_check["★결정론 conflict_check<br/>룰 기반 충돌 검사"]
        var_engine["★결정론 var_engine<br/>VaR/CVaR·스트레스 계산"]
        assemble_report["★결정론 assemble_report<br/>리포트 조립"]
    end

    subgraph LLM["LLM 계층"]
        extract_ips["★LLM extract_ips<br/>Structured Output IPS 추출"]
        rag_cite["★LLM rag_cite<br/>RAG 설명·검증 인용 생성"]
        judge_eval["★LLM judge_eval<br/>6축 LLM-as-Judge 평가"]
    end

    subgraph HITL["HITL 계층"]
        approval_gate["★HITL approval_gate<br/>PB 승인 게이트 · interrupt_before"]
    end

    load_inputs --> extract_ips
    extract_ips --> conflict_check
    conflict_check -- "분기① 충돌 & retries < 1" --> extract_ips
    conflict_check -- "충돌 없음 or 재시도 소진" --> approval_gate
    approval_gate -. "② interrupt_before<br/>(사람 승인 대기)" .-> approval_gate
    approval_gate --> var_engine
    var_engine --> rag_cite
    rag_cite --> judge_eval
    judge_eval -- "분기③ 불통과 & judge_retries < 2" --> rag_cite
    judge_eval -- "통과 or 2회 도달<br/>(실패 시 수동검토)" --> assemble_report
    assemble_report --> END([END])
