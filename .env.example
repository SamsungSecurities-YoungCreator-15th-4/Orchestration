# Azure OpenAI (LLM 노드 실제 연결 시 필요 — 스켈레톤 실행에는 불필요)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
# gpt-4o Azure 배포명
AZURE_OPENAI_DEPLOYMENT=
# RAG 임베딩용 배포명 (text-embedding-3-small)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# LangSmith 트레이싱 (선택, 실제 고객정보 입력 전 팀 보안·보존정책 확인)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=Orchestration_Team4
# 금융 상담 원문·State가 trace payload로 외부 전송되지 않도록 기본 마스킹
LANGSMITH_HIDE_INPUTS=true
LANGSMITH_HIDE_OUTPUTS=true
